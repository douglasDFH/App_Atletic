<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".AtletismoApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TallerAppMovil"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".auth.RegisterActivity"       android:exported="false" />
        <activity android:name=".auth.ForgotPasswordActivity" android:exported="false" />

        <activity android:name=".auth.ResetPasswordActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="atletismo" android:host="reset" />
            </intent-filter>
        </activity>

        <activity android:name=".dashboard.DashboardActivity"           android:exported="false" />
        <activity android:name=".dashboard.AtletaDashboardActivity"     android:exported="false" />
        <activity android:name=".dashboard.EntrenadorDashboardActivity" android:exported="false" />

        <activity android:name=".agenda.AgendaActivity"         android:exported="false" />
        <activity android:name=".agenda.CrearSesionActivity"  android:exported="false" />
        <activity android:name=".agenda.SesionDetalleActivity" android:exported="false" />
        <activity android:name=".asistencia.AsistenciaActivity"         android:exported="false" />
        <activity android:name=".asistencia.HistorialAsistenciaActivity" android:exported="false" />

        <activity android:name=".atletas.AtletasActivity"         android:exported="false" />
        <activity android:name=".atletas.AtletaPerfilActivity"  android:exported="false" />
        <activity android:name=".atletas.EditarAtletaActivity"  android:exported="false" />

        <activity android:name=".grupos.GruposActivity"         android:exported="false" />
        <activity android:name=".grupos.GrupoDetalleActivity"   android:exported="false" />
        <activity android:name=".grupos.CrearGrupoActivity"     android:exported="false" />

        <activity android:name=".ranking.RankingActivity"         android:exported="false" />

        <activity android:name=".marcas.MarcasActivity"            android:exported="false" />
        <activity android:name=".marcas.RegistrarMarcaActivity"  android:exported="false" />
        <activity android:name=".marcas.EvolucionMarcasActivity" android:exported="false" />
        <activity android:name=".eventos.EventosActivity"              android:exported="false" />
        <activity android:name=".eventos.CrearCompetenciaActivity"   android:exported="false" />
        <activity android:name=".eventos.CompetenciaDetalleActivity" android:exported="false" />
        <activity android:name=".notificaciones.NotificacionesActivity"   android:exported="false" />
        <activity android:name=".perfil.CambiarContrasenaActivity"         android:exported="false" />
        <activity android:name=".perfil.EditarPerfilActivity"            android:exported="false" />
        <activity android:name=".asistencia.ReporteAsistenciaActivity"     android:exported="false" />
        <activity android:name=".grupos.SeleccionarAtletasActivity"       android:exported="false" />

        <activity android:name=".estadisticas.EstadisticasActivity" android:exported="false" />

        <activity android:name=".perfil.PerfilActivity"   android:exported="false" />

        <activity android:name=".MainActivity" android:exported="false" />

        <service
            android:name=".notificaciones.PushNotificationService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>
