<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_card_sesion"
    android:clickable="false"
    android:focusable="false">

    <!-- Panel izquierdo: fecha -->
    <LinearLayout
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="10dp"
        android:background="@color/colorSurfaceVariant">

        <TextView
            android:id="@+id/tvDia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary" />

        <TextView
            android:id="@+id/tvMes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/colorTextSecondary" />
    </LinearLayout>

    <!-- Panel derecho: detalle -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvDisciplina"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/tvPR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ PR"
                android:textSize="11sp"
                android:textColor="@color/colorPending"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvResultado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvAtletaNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvObservaciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="2dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Botón eliminar (solo visible para entrenador) -->
    <TextView
        android:id="@+id/tvEliminar"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="✕"
        android:textSize="16sp"
        android:textColor="@color/colorCancelled"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />
</LinearLayout>
