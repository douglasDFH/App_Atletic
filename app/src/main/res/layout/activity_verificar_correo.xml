<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    android:gravity="center_vertical"
    android:padding="32dp">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:src="@android:drawable/ic_dialog_email"
        android:tint="@color/colorPrimary" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/lbl_verificar_correo"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextPrimary"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/lbl_verificar_correo_desc"
        android:textSize="14sp"
        android:textColor="@color/colorTextSecondary"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilCodigo"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_codigo_verificacion"
        app:boxStrokeColor="@color/colorPrimary"
        app:hintTextColor="@color/colorTextSecondary"
        android:layout_marginBottom="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCodigo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextPrimary"
            android:inputType="textNoSuggestions"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPegar"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="📋  Pegar código del correo"
        android:textSize="13sp"
        android:textColor="@color/colorPrimary"
        app:strokeColor="@color/colorPrimary"
        android:layout_marginBottom="20dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerificar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_verificar"
        android:textSize="16sp"
        android:textColor="@color/colorOnPrimary"
        android:backgroundTint="@color/colorPrimary"
        android:layout_marginBottom="16dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvReenviar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="¿No recibiste el correo? Reenviar"
        android:textColor="@color/colorPrimary"
        android:gravity="center"
        android:padding="8dp"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvVolver"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Volver al inicio de sesión"
        android:textColor="@color/colorTextSecondary"
        android:gravity="center"
        android:padding="8dp" />

</LinearLayout>
