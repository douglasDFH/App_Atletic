<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorSurface"
        app:titleTextColor="@color/colorTextPrimary"
        app:navigationIconTint="@color/colorTextPrimary"
        app:title="@string/lbl_agenda" />

    <!-- Navegación semanal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/colorSurfaceVariant"
        android:paddingHorizontal="8dp">

        <TextView
            android:id="@+id/btnPrevSemana"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="◄"
            android:textSize="18sp"
            android:textColor="@color/colorPrimary"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/tvSemana"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary" />

        <TextView
            android:id="@+id/btnNextSemana"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="►"
            android:textSize="18sp"
            android:textColor="@color/colorPrimary"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Filtros: búsqueda + chips de estado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorSurface"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="2dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilBuscar"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_buscar_sesion"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="@color/colorTextSecondary"
            app:boxStrokeColor="@color/colorBorder"
            app:hintTextColor="@color/colorTextSecondary"
            app:boxBackgroundColor="@color/colorSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBuscar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionSearch"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="@color/colorTextHint" />
        </com.google.android.material.textfield.TextInputLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingTop="4dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                android:paddingHorizontal="2dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTodos"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_todos"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMiGrupo"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi grupo"
                    android:visibility="gone" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipProgramadas"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_programadas" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipActivas"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_activas" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFinalizadas"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_finalizadas" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCanceladas"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_canceladas" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <TextView
            android:id="@+id/tvContadorSesiones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/colorTextSecondary"
            android:paddingTop="2dp"
            android:paddingBottom="4dp"
            android:paddingStart="2dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Área de contenido -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvVacio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/lbl_sin_entrenamientos"
            android:textSize="15sp"
            android:textColor="@color/colorTextSecondary"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSesiones"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabCrear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:contentDescription="@string/lbl_crear_sesion"
            android:src="@android:drawable/ic_input_add"
            app:backgroundTint="@color/colorPrimary"
            app:tint="@color/colorOnPrimary"
            android:visibility="gone" />
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        app:menu="@menu/menu_bottom_nav"
        app:itemIconTint="@drawable/nav_item_color"
        app:itemTextColor="@drawable/nav_item_color"
        app:labelVisibilityMode="labeled" />
</LinearLayout>
