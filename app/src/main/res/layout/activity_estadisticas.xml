<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorSurface"
        app:titleTextColor="@color/colorTextPrimary"
        app:navigationIconTint="@color/colorTextPrimary"
        app:title="@string/lbl_estadisticas_titulo" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Mes actual -->
            <TextView
                android:id="@+id/tvMesActual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextSecondary"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <!-- Fila stats: Atletas + Próx Competencias -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_card_stat"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ATLETAS ACTIVOS"
                        android:textSize="9sp"
                        android:textAllCaps="true"
                        android:textColor="@color/colorTextSecondary" />
                    <TextView
                        android:id="@+id/tvTotalAtletas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="88dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_stat"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRÓX COMPETENCIAS"
                        android:textSize="9sp"
                        android:textAllCaps="true"
                        android:textColor="@color/colorTextSecondary" />
                    <TextView
                        android:id="@+id/tvProxCompetencias"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPending" />
                </LinearLayout>

            </LinearLayout>

            <!-- Card asistencia promedio grande -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_stat"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ASISTENCIA PROMEDIO"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:textColor="@color/colorTextSecondary"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvPromedioAsistencia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--%"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorActive"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvResumenSesiones"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tvPresentes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorActive"
                        android:gravity="center" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="presentes"
                        android:textSize="10sp"
                        android:textColor="@color/colorTextSecondary"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tvAusentes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorCancelled"
                        android:gravity="center"
                        android:layout_marginTop="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ausentes"
                        android:textSize="10sp"
                        android:textColor="@color/colorTextSecondary"
                        android:gravity="center" />

                </LinearLayout>
            </LinearLayout>

            <!-- Sección: Ranking de Asistencia -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RANKING DE ASISTENCIA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextSecondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/layoutRanking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_stat"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/tvSinReporte"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/lbl_sin_reporte"
                    android:textSize="13sp"
                    android:textColor="@color/colorTextSecondary"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRanking"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

            <!-- Sección: Próximas Competencias -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PRÓXIMAS COMPETENCIAS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextSecondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/layoutProxEventos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_stat"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvSinEventos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/lbl_sin_eventos"
                    android:textSize="13sp"
                    android:textColor="@color/colorTextSecondary"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
