<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorSurface"
        app:titleTextColor="@color/colorTextPrimary"
        app:title="@string/lbl_eventos_titulo" />

    <!-- Cabecera: búsqueda + chips de filtro -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorSurface"
        android:paddingHorizontal="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp">

        <!-- Barra de búsqueda -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilBuscar"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_buscar_evento"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="@color/colorTextSecondary"
            app:boxStrokeColor="@color/colorBorder"
            app:hintTextColor="@color/colorTextSecondary"
            app:boxBackgroundColor="@color/colorSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBuscar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionSearch"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="@color/colorTextHint" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Chips de filtro por estado -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingTop="6dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                android:paddingHorizontal="2dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTodos"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_todos"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipProximos"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_proximos" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipEnCurso"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_en_curso" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFinalizados"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_finalizados" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Contador de resultados -->
        <TextView
            android:id="@+id/tvContadorEventos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/colorTextSecondary"
            android:paddingTop="4dp"
            android:paddingBottom="6dp"
            android:paddingStart="2dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Contenido -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvVacio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/lbl_sin_eventos"
            android:textSize="15sp"
            android:textColor="@color/colorTextSecondary"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerEventos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabNuevoEvento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="@string/lbl_crear_competencia"
            app:backgroundTint="@color/colorPrimary"
            app:tint="@color/colorOnPrimary"
            android:visibility="gone" />
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        app:menu="@menu/menu_bottom_nav"
        app:itemIconTint="@drawable/nav_item_color"
        app:itemTextColor="@drawable/nav_item_color"
        app:labelVisibilityMode="labeled" />
</LinearLayout>
