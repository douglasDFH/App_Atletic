<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Ícono tipo (emoji en círculo pequeño) -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_avatar"
        android:backgroundTint="@color/colorSurfaceVariant">
        <TextView
            android:id="@+id/tvIconoActividad"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="16sp" />
    </FrameLayout>

    <!-- Título + tiempo -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTituloActividad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/colorTextPrimary"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvMensajeActividad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="1dp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Tiempo + punto no leída -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/tvTiempoActividad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/colorTextSecondary"
            android:gravity="end" />

        <View
            android:id="@+id/viewPuntoNoLeida"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_marginTop="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_avatar"
            android:backgroundTint="@color/colorPrimary"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
