<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header: saludo + avatar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSaludo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hola 👋"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:id="@+id/tvSubtitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/colorTextSecondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Botón notificaciones -->
                <FrameLayout
                    android:id="@+id/btnNotificaciones"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:background="@drawable/bg_avatar"
                    android:backgroundTint="@color/colorSurfaceVariant">
                    <TextView
                        android:id="@+id/tvCampana"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="🔔"
                        android:textSize="17sp" />
                    <!-- Badge contador no leídas -->
                    <TextView
                        android:id="@+id/tvBadgeNotif"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="2dp"
                        android:background="@drawable/bg_avatar"
                        android:backgroundTint="@color/colorCancelled"
                        android:gravity="center"
                        android:textSize="9sp"
                        android:textColor="@color/colorTextPrimary"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/avatarCircle"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_avatar">
                    <TextView
                        android:id="@+id/tvAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorOnPrimary" />
                </FrameLayout>
            </LinearLayout>

            <!-- Grid de estadísticas 2x2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:id="@+id/cardAtletas"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_card_stat"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ATLETAS ACTIVOS"
                        android:textSize="9sp"
                        android:textColor="@color/colorTextSecondary"
                        android:textAllCaps="true" />
                    <TextView
                        android:id="@+id/tvAtletas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardAsistenciaHoy"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_stat"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ASISTENCIA HOY"
                        android:textSize="9sp"
                        android:textColor="@color/colorTextSecondary"
                        android:textAllCaps="true" />
                    <TextView
                        android:id="@+id/tvAsistenciaHoy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorActive" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/cardProxCompetencia"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_card_stat"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRÓX. COMPETENCIA"
                        android:textSize="9sp"
                        android:textColor="@color/colorTextSecondary"
                        android:textAllCaps="true" />
                    <TextView
                        android:id="@+id/tvProxCompetencia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardNuevasMarcas"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_stat"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NUEVAS MARCAS"
                        android:textSize="9sp"
                        android:textColor="@color/colorTextSecondary"
                        android:textAllCaps="true" />
                    <TextView
                        android:id="@+id/tvNuevasMarcas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPending" />
                </LinearLayout>
            </LinearLayout>

            <!-- Sesión de hoy -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lbl_sesion_hoy"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextSecondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/cardSesionHoy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_sesion"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvSesionNombre"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/lbl_sin_sesion_hoy"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:id="@+id/tvSesionEstado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Activo"
                        android:textSize="11sp"
                        android:textColor="@color/colorOnPrimary"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@color/colorActive"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSesionDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layoutBotonesSesion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTomarAsistencia"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="@string/lbl_tomar_asistencia"
                        android:textSize="12sp"
                        app:strokeColor="@color/colorPrimary"
                        android:textColor="@color/colorPrimary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerAgenda"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="@string/lbl_ver_agenda"
                        android:textSize="12sp"
                        app:strokeColor="@color/colorBorder"
                        android:textColor="@color/colorTextSecondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Accesos rápidos (solo entrenador) -->
            <LinearLayout
                android:id="@+id/layoutAccesosEntrenador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GESTIÓN"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextSecondary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:id="@+id/cardGrupos"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card_stat"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/lbl_grupos_titulo"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardReporte"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card_stat"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/lbl_reporte_asistencia"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardEstadisticas"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card_stat"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/lbl_estadisticas_titulo"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>

            </LinearLayout>

            <!-- Actividad reciente -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lbl_actividad_reciente"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextSecondary"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/layoutActividad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_stat"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvSinActividad"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin actividad reciente"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorSurface"
        app:menu="@menu/menu_bottom_nav"
        app:itemIconTint="@drawable/nav_item_color"
        app:itemTextColor="@drawable/nav_item_color"
        app:itemActiveIndicatorColor="@color/colorSurfaceVariant"
        app:labelVisibilityMode="labeled" />

</LinearLayout>
