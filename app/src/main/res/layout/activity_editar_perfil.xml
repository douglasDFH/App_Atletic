<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorSurface"
        app:titleTextColor="@color/colorTextPrimary"
        app:navigationIconTint="@color/colorTextPrimary"
        app:title="@string/lbl_editar_perfil" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Avatar con selector de foto -->
            <FrameLayout
                android:id="@+id/frameAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_avatar"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">
                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorOnPrimary" />
                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="@string/lbl_foto_perfil" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="22dp"
                    android:layout_gravity="bottom"
                    android:gravity="center"
                    android:text="✎"
                    android:textSize="11sp"
                    android:textColor="@color/colorOnPrimary"
                    android:background="#88000000" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="20dp"
                android:text="@string/lbl_cambiar_foto"
                android:textSize="12sp"
                android:textColor="@color/colorPrimary" />

            <!-- Nombre (solo lectura — no editable por el atleta, HU-13) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/hint_nombre"
                app:boxBackgroundColor="@color/colorSurface"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/colorBorder"
                app:hintTextColor="@color/colorTextSecondary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:enabled="false"
                    android:inputType="none"
                    android:textColor="@color/colorTextSecondary"
                    android:alpha="0.7" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/hint_correo"
                app:boxBackgroundColor="@color/colorSurface"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/colorBorder"
                app:hintTextColor="@color/colorTextSecondary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/colorTextPrimary" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Teléfono (opcional, HU-13) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTelefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/hint_telefono"
                app:boxBackgroundColor="@color/colorSurface"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/colorBorder"
                app:hintTextColor="@color/colorTextSecondary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTelefono"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="@color/colorTextPrimary" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Contraseña actual (requerida para confirmar cambios, HU-13) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilContrasenaActual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:hint="@string/hint_contrasena_actual"
                app:boxBackgroundColor="@color/colorSurface"
                app:boxBackgroundMode="outline"
                app:boxStrokeColor="@color/colorBorder"
                app:hintTextColor="@color/colorTextSecondary"
                app:passwordToggleEnabled="true"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etContrasenaActual"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/colorTextPrimary" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/btn_guardar_perfil"
                android:textSize="15sp"
                android:backgroundTint="@color/colorPrimary"
                android:textColor="@color/colorOnPrimary" />

            <!-- Loading overlay -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
